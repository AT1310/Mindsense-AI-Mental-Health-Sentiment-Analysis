{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/context/*": [
        "./context/*"
      ],
      "@/models/*": [
        "../database/models/*"
      ],
      "@/lib/db": [
        "../database/db.ts"
      ],
      "@/lib/ai": [
        "../backend/lib/ai.ts"
      ],
      "@/lib/analyzer": [
        "../backend/lib/analyzer.ts"
      ],
      "@/lib/auth": [
        "../backend/lib/auth.ts"
      ],
      "@/lib/email": [
        "../backend/lib/email.ts"
      ],
      "@/lib/storage": [
        "../backend/lib/storage.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}